    <DockPanel MinHeight="80" LastChildFill="True">
        
        <Border Name="CoverBorder" Background="Silver" DockPanel.Dock="Left">
            <Image Name="CoverImage" Width="70" Stretch="UniformToFill"/>
        </Border>
        <Button DockPanel.Dock="Right" Name="FavoritesButton">
            <PathIcon Name="FavoritesIcon" Data="{StaticResource star-regular}" Foreground="DarkOrange"/>
        </Button>

        <StackPanel Margin="10,5,10,5" VerticalAlignment="Center">
            <TextBlock Name="TitleTextBlock"
FontSize="18" 
                       FontWeight="SemiBold"
                       TextTrimming="CharacterEllipsis">
                Dragon Balls
            </TextBlock>
            
            <TextBlock Name="CategoryTextBlock" 
                       FontSize="13" 
                       Foreground="Gray">Action</TextBlock>
            
            <TextBlock Name="StatusTextBlock" 
                       FontSize="13" 
                       Foreground="Gray">completed</TextBlock>
        </StackPanel>
        
    </DockPanel>
</UserControl>